---
const placeholders = [
  { nombre: '[Nombre del emprendedor]', emprendimiento: '[Nombre del emprendimiento]', texto: 'Testimonio por completar — la fundación debe proveer citas reales de emprendedores que participaron.' },
  { nombre: '[Nombre del emprendedor]', emprendimiento: '[Nombre del emprendimiento]', texto: 'Testimonio por completar — la fundación debe proveer citas reales de emprendedores que participaron.' },
  { nombre: '[Nombre del emprendedor]', emprendimiento: '[Nombre del emprendimiento]', texto: 'Testimonio por completar — la fundación debe proveer citas reales de emprendedores que participaron.' },
];
---

<section class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">Lo que dicen nuestros miembros</h2>
    <p class="text-center text-gray-500 mb-12 font-body max-w-xl mx-auto">Historias reales de emprendedores que transformaron su negocio.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {placeholders.map(t => (
        <div class="bg-gray-50 rounded-2xl p-7 flex flex-col gap-4">
          <svg class="text-secondary w-7 h-7 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="font-body text-sm text-gray-500 leading-relaxed italic flex-1">{t.texto}</p>
          <div>
            <p class="font-heading text-sm font-semibold text-gray-800">{t.nombre}</p>
            <p class="font-body text-xs text-secondary">{t.emprendimiento}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
