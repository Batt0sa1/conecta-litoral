---
const valores = [
  'Compromiso social',
  'Cercanía',
  'Transparencia',
  'Colaboración',
  'Creatividad',
  'Respeto',
  'Inclusión',
  'Responsabilidad',
  'Empatía',
  'Innovación social',
];
---

<section class="py-20 px-4 bg-primary">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-4">Nuestros Valores</h2>
    <p class="text-white/60 mb-12 font-body">Los principios que guían nuestra comunidad.</p>

    <div class="flex flex-wrap justify-center gap-3">
      {valores.map(v => (
        <span class="bg-white/10 border border-white/20 text-white font-body text-sm px-5 py-2.5 rounded-full hover:bg-white/20 transition">
          {v}
        </span>
      ))}
    </div>
  </div>
</section>
