---
const base = import.meta.env.BASE_URL;
const fotos = [
  { src: `${base}images/foto-grupal-de-todos-los-fundadores.webp`, alt: 'Foto grupal de los fundadores de Conecta Litoral' },
  { src: `${base}images/persona-hablando-en-charla.webp`, alt: 'Charla de capacitación para emprendedores' },
  { src: `${base}images/foto-de-fundadores.webp`, alt: 'Fundadores de Conecta Litoral' },
  { src: `${base}images/imagen-que-muestra-beneficios.webp`, alt: 'Beneficios de la membresía Conecta Litoral' },
];
---

<section id="galeria" class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">Galería de Actividades</h2>
    <p class="text-center text-gray-500 mb-12 font-body max-w-xl mx-auto">
      Momentos reales de nuestra comunidad en acción.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {fotos.map(f => (
        <div class="rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow aspect-square">
          <img
            src={f.src}
            alt={f.alt}
            loading="lazy"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
          />
        </div>
      ))}
    </div>
  </div>
</section>
