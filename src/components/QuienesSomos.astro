---
const stats = [
  { value: '—', label: 'Emprendedores apoyados' },
  { value: '—', label: 'Talleres realizados' },
  { value: '—', label: 'Alianzas estratégicas' },
  { value: '—', label: 'Años de trayectoria' },
];
---

<section id="quienes-somos" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">¿Quiénes Somos?</h2>
    <p class="text-center text-gray-500 mb-14 max-w-2xl mx-auto font-body">
      Fundación sin fines de lucro que impulsa a emprendedores y comerciantes a través de capacitación, asesorías, redes y oportunidades.
    </p>

    <div class="grid md:grid-cols-3 gap-8 mb-16">
      <!-- Visión -->
      <div class="bg-primary/10 rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-lg transition-shadow">
        <div class="bg-primary/15 rounded-full p-5 mb-5 group-hover:bg-primary/25 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-primary mb-3">Visión</h3>
        <div class="w-10 h-0.5 bg-primary/40 rounded mb-4"></div>
        <p class="font-body text-gray-600 text-sm leading-relaxed">
          Ser una fundación referente en el desarrollo social, cultural y comunitario del litoral.
        </p>
      </div>

      <!-- Misión -->
      <div class="bg-secondary/10 rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-lg transition-shadow">
        <div class="bg-secondary/15 rounded-full p-5 mb-5 group-hover:bg-secondary/25 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-secondary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-secondary mb-3">Misión</h3>
        <div class="w-10 h-0.5 bg-secondary/40 rounded mb-4"></div>
        <p class="font-body text-gray-600 text-sm leading-relaxed">
          Conectar personas, talentos y oportunidades, generando impacto en las comunidades del litoral.
        </p>
      </div>

      <!-- Objetivo -->
      <div class="bg-cta/10 rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-lg transition-shadow">
        <div class="bg-cta/15 rounded-full p-5 mb-5 group-hover:bg-cta/25 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-yellow-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-yellow-700 mb-3">Objetivo</h3>
        <div class="w-10 h-0.5 bg-cta/60 rounded mb-4"></div>
        <p class="font-body text-gray-600 text-sm leading-relaxed">
          Crear espacios y programas que fortalezcan el desarrollo humano, cultural y económico del litoral.
        </p>
      </div>
    </div>

    <!-- Impact numbers -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 bg-primary rounded-2xl px-8 py-10">
      {stats.map(s => (
        <div class="text-center">
          <p class="font-heading text-4xl font-bold text-cta mb-1">{s.value}</p>
          <p class="font-body text-white/70 text-sm">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
