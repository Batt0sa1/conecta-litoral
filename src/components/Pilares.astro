---

<section class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">Nuestros Pilares</h2>
    <p class="text-center text-gray-500 mb-12 font-body max-w-xl mx-auto">Los valores que guían cada acción y programa de la fundación.</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
      {pilares.map(p => (
        <div class="bg-white rounded-2xl p-7 text-center shadow-sm hover:shadow-md transition-shadow">
          <div class="text-primary flex justify-center mb-4" set:html={p.icon} />
          <h3 class="font-heading text-base font-semibold text-gray-800">{p.nombre}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
