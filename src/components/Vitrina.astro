---
const emprendimientos = [
  {
    nombre: 'Tu emprendimiento aquí',
    rubro: 'Gastronomía',
    descripcion: 'Descripción breve del emprendimiento y sus productos o servicios. Próximamente este espacio mostrará tu negocio.',
    inicial: 'E',
    color: 'bg-primary/20 text-primary',
    contacto: '',
  },
  {
    nombre: 'Tu emprendimiento aquí',
    rubro: 'Artesanía',
    descripcion: 'Descripción breve del emprendimiento y sus productos o servicios. Próximamente este espacio mostrará tu negocio.',
    inicial: 'E',
    color: 'bg-secondary/20 text-secondary',
    contacto: '',
  },
  {
    nombre: 'Tu emprendimiento aquí',
    rubro: 'Servicios',
    descripcion: 'Descripción breve del emprendimiento y sus productos o servicios. Próximamente este espacio mostrará tu negocio.',
    inicial: 'E',
    color: 'bg-cta/20 text-yellow-700',
    contacto: '',
  },
];
---

<section id="vitrina" class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">Vitrina de Emprendimientos</h2>
    <p class="text-center text-gray-500 mb-3 font-body max-w-2xl mx-auto">
      Conoce a los emprendedores que forman parte de nuestra comunidad.
    </p>
    <p class="text-center text-secondary text-sm font-medium mb-12">
      Próximamente presentaremos los emprendimientos de nuestros socios.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {emprendimientos.map(e => (
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col">
          <!-- Área de imagen / placeholder -->
          <div class={`h-36 flex items-center justify-center ${e.color} relative`}>
            <span class="font-heading text-5xl font-bold opacity-30">{e.inicial}</span>
            <span class="absolute top-3 right-3 bg-white/80 text-xs font-medium text-gray-500 px-2.5 py-1 rounded-full">
              Próximamente
            </span>
          </div>

          <!-- Contenido -->
          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="font-heading text-base font-bold text-primary leading-snug">{e.nombre}</h3>
              <span class="shrink-0 border border-secondary text-secondary text-xs font-medium px-2.5 py-0.5 rounded-full">
                {e.rubro}
              </span>
            </div>
            <p class="font-body text-gray-500 text-sm leading-relaxed flex-1">{e.descripcion}</p>

            <!-- Contacto (deshabilitado en placeholder) -->
            <div class="mt-5 pt-4 border-t border-gray-100">
              <span class="inline-flex items-center gap-2 text-gray-300 text-sm cursor-not-allowed select-none">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                Contactar
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center mt-10 text-gray-400 text-sm font-body">
      ¿Eres socio y quieres aparecer aquí?
      <a href="#membresias" class="text-secondary font-medium hover:underline">Súmate a una membresía →</a>
    </p>
  </div>
</section>
