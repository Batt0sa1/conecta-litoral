<section id="contacto" class="py-20 px-4 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">Contáctanos</h2>
    <p class="text-center text-gray-500 mb-14 font-body max-w-xl mx-auto">
      ¿Tienes dudas? Escríbenos por cualquiera de nuestros canales o usa el formulario.
    </p>

    <div class="grid md:grid-cols-2 gap-10">
      <!-- Contact info -->
      <div class="flex flex-col gap-6 justify-center">
        <a
          href="https://wa.me/56927698014"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 bg-white rounded-2xl px-6 py-5 shadow-sm hover:shadow-md transition-shadow group"
        >
          <div class="bg-green-100 text-green-600 rounded-full p-3 shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          </div>
          <div>
            <p class="font-heading text-sm font-semibold text-gray-800 group-hover:text-secondary transition-colors">WhatsApp</p>
            <p class="font-body text-sm text-gray-500">+56 9 2769 8014</p>
          </div>
        </a>

        <a
          href="https://instagram.com/conecta_litoral_chile"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 bg-white rounded-2xl px-6 py-5 shadow-sm hover:shadow-md transition-shadow group"
        >
          <div class="bg-pink-100 text-pink-600 rounded-full p-3 shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </div>
          <div>
            <p class="font-heading text-sm font-semibold text-gray-800 group-hover:text-secondary transition-colors">Instagram</p>
            <p class="font-body text-sm text-gray-500">@conecta_litoral_chile</p>
          </div>
        </a>

        <a
          href="https://facebook.com/conecta_litoral_chile"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 bg-white rounded-2xl px-6 py-5 shadow-sm hover:shadow-md transition-shadow group"
        >
          <div class="bg-blue-100 text-blue-600 rounded-full p-3 shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </div>
          <div>
            <p class="font-heading text-sm font-semibold text-gray-800 group-hover:text-secondary transition-colors">Facebook</p>
            <p class="font-body text-sm text-gray-500">@conecta_litoral_chile</p>
          </div>
        </a>
      </div>

      <!-- Contact form -->
      <div class="bg-white rounded-2xl p-8 shadow-sm">
        <h3 class="font-heading text-lg font-semibold text-gray-800 mb-6">Envíanos un mensaje</h3>
        <form id="form-contacto" class="flex flex-col gap-4">
          <div>
            <label class="block text-gray-600 text-sm font-medium mb-1.5" for="c-nombre">Nombre *</label>
            <input required id="c-nombre" name="nombre" type="text" placeholder="Tu nombre"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
          </div>
          <div>
            <label class="block text-gray-600 text-sm font-medium mb-1.5" for="c-email">Email *</label>
            <input required id="c-email" name="email" type="email" placeholder="tu@correo.cl"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" />
          </div>
          <div>
            <label class="block text-gray-600 text-sm font-medium mb-1.5" for="c-mensaje">Mensaje *</label>
            <textarea required id="c-mensaje" name="mensaje" rows="4" placeholder="¿En qué podemos ayudarte?"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary resize-none"></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input required id="c-consent" name="consent" type="checkbox" class="mt-1 accent-primary w-4 h-4 shrink-0" />
            <label for="c-consent" class="text-gray-400 text-xs leading-relaxed">
              Acepto el tratamiento de mis datos personales conforme a la Ley 19.628.
            </label>
          </div>
          <button type="submit" id="btn-contacto"
            class="bg-primary text-white font-heading font-semibold py-3 rounded-full hover:brightness-110 transition disabled:opacity-60">
            Enviar mensaje
          </button>
          <div id="msg-contacto" class="hidden text-center text-sm font-medium rounded-xl px-4 py-3"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('form-contacto') as HTMLFormElement;
  const btn = document.getElementById('btn-contacto') as HTMLButtonElement;
  const msg = document.getElementById('msg-contacto') as HTMLDivElement;
  const ENDPOINT = import.meta.env.PUBLIC_FORMSPREE_CONTACTO || 'https://formspree.io/f/YYYYYYYY';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Enviando…';

    const data = new FormData(form);
    try {
      const res = await fetch(ENDPOINT, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        msg.className = 'text-center text-sm font-medium rounded-xl px-4 py-3 bg-green-100 text-green-700';
        msg.textContent = '¡Mensaje enviado! Te responderemos a la brevedad.';
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      msg.className = 'text-center text-sm font-medium rounded-xl px-4 py-3 bg-red-100 text-red-600';
      msg.textContent = 'Hubo un problema. Por favor intenta de nuevo o contáctanos por WhatsApp.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>
