---

<section id="asesorias" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">Asesorías Profesionales</h2>
    <p class="text-center text-gray-500 mb-12 font-body max-w-xl mx-auto">
      Acceso a expertos en distintas áreas para que tu emprendimiento crezca con base sólida.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {asesorias.map(a => (
        <div class="flex gap-4 items-start bg-gray-50 rounded-2xl p-6 hover:shadow-md transition-shadow">
          <div class="text-secondary shrink-0 mt-0.5" set:html={a.icon} />
          <div>
            <h3 class="font-heading text-base font-semibold text-gray-800 mb-1">{a.nombre}</h3>
            <p class="font-body text-sm text-gray-500 leading-relaxed">{a.descripcion}</p>
          </div>
        </div>
      ))}
      <div class="flex gap-4 items-center justify-center bg-primary/5 border-2 border-dashed border-primary/30 rounded-2xl p-6 sm:col-span-2 lg:col-span-1">
        <p class="font-body text-sm text-primary/70 text-center">
          Asesorías incluidas en tu membresía.<br />
          <a href="#membresias" class="text-secondary font-medium hover:underline">Súmate hoy →</a>
        </p>
      </div>
    </div>
  </div>
</section>
