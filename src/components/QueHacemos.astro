---

<section id="que-hacemos" class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-4">¿Qué Hacemos?</h2>
    <p class="text-center text-gray-500 mb-12 font-body max-w-xl mx-auto">
      Seis líneas de acción que impulsan el desarrollo del litoral desde adentro.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {acciones.map(a => (
        <div class="bg-white rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow">
          <div class="text-secondary mb-4" set:html={a.icon} />
          <h3 class="font-heading text-base font-semibold text-gray-800 mb-2">{a.nombre}</h3>
          <p class="font-body text-sm text-gray-500 leading-relaxed">{a.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>
